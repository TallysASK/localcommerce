from flask import Flask-, render_template, request, url_for, session, redirect, Blueprint, abort
from flask_login import login_required, login_user, logout_user, current_user
from db import db
from models import Loja, Produtos

store_bp = Blueprint("store", __name__)

# Perfil loja

@store_bp.route("/store/<username>")
def store(username):
    loja = Loja.query.filter_by(username=username).first()
    
    if not loja:
        return abort(404)
    
    return render_template("store/store.html", loja=loja)

# Editar perfil loja   

@store_bp.route("/store/edit", methods=["GET" , "POST"])
@login_required
def editstore():
    
    if request.method == "POST":
        novo_viewname = request.form.get("nomeLj")
        descricao = request.form.get("descricaoLj")
        
        if not novo_viewname:
            novo_viewname = current_user.username
        if not descricao:
            descricao = "descrição"
            
        current_user.viewname = novo_viewname
        current_user.descricao = descricao
        db.session.commit()
        
        return redirect(url_for("store.store", username=current_user.username))
    
    return render_template("store/edit_store.html")
    
@store_bp.route("/produtos/<loja>")
def produtos(loja):
    loja = Loja.query.filter_by(username=loja)
    produtos = loja.produtos
    
    return render_template("store/produtos.html", produtos=produtos)

@store_bp.route("/produtos/edit",  methods=["GET", "POST"])
@login_required
def editprodutos():
    # Puxar dos formularios os valores de editar e adicionar; ligar a tabela produtos
    for key , value in request.form.items():
        
        if key startswith("nomeProduto_"):
            produto_id = key.split("_")[1]

            nome = value

        preco = request.form[f"precoProduto_{produto_id}"]
        quant = request.form[f"quantProduto_{produto_id}"]
        mostrar = request.form.get(f"mostrarProduto_{produto_id}") == "Sim"

        produto = Produto.query.get(int(produto_id))

        if produto:
            produto.nome = nome
            produto.preco =float(preco)
            produto.quant = int(quant)
            produto.mostrar = mostrar
        
    db.session.commit()
    return render_template("store/edit_produtos.html")
